{
  "name": "paulmowat.co.uk",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start": "cross-env TAILWIND_MODE=watch next-remote-watch ./data",
    "dev": "cross-env NODE_OPTIONS='--inspect' next dev",
    "build": "prisma generate && prisma migrate deploy && next build",
    "postbuild": "node ./scripts/generate-sitemap.mjs",
    "serve": "next start",
    "analyze": "cross-env ANALYZE=true next build",
    "prepare": "husky",
    "lint": "standard --fix",
    "prisma": "prisma",
    "deploy-db": "prisma generate && prisma migrate deploy"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.6",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@vercel/postgres": "^0.10.0",
    "autoprefixer": "^10.5.0",
    "gray-matter": "^4.0.3",
    "image-size": "^2.0.2",
    "next": "^16.2.6",
    "next-mdx-remote": "^6.0.0",
    "next-pwa": "^5.6.0",
    "next-seo": "7.2.0",
    "next-themes": "^0.4.6",
    "pg": "^8.21.0",
    "postcss": "^8.5.15",
    "preact": "^10.29.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-vertical-timeline-component": "^4.0.0",
    "reading-time": "1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-prism-plus": "^2.0.2",
    "rehype-slug": "^6.0.0",
    "remark-footnotes": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "swr": "2.4.1",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.6",
    "@prisma/client": "^7.8.0",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4.3.0",
    "cross-env": "^10.1.0",
    "file-loader": "^6.2.0",
    "globby": "16.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "next-compose-plugins": "^2.2.1",
    "next-remote-watch": "^2.0.0",
    "prisma": "^7.8.0",
    "rehype": "13.0.2",
    "remark-frontmatter": "5.0.0",
    "remark-parse": "11.0.0",
    "remark-stringify": "11.0.0",
    "standard": "^17.1.2",
    "unified": "11.0.5",
    "unist-util-visit": "5.1.0"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx)": [
      "standard --fix"
    ]
  },
  "standard": {
    "ignore": [
      "/public/sw.js",
      "/public/workbox-*.js"
    ]
  }
}
